#!/bin/sh

# Phase 4: Mark-gated offload temporarily disabled.
# Standard fw4 flow offload (flow_offloading=1 + flow_offloading_hw=1)
# handles all hardware NPU offload via the kernel flowtable path.
#
# The XDP DSCP-based mark-gated offload (0xAF01-0xAF04 classes) will
# be re-enabled once the full XDP->skb mark pipeline is verified
# end-to-end. See ADR-001 Phase 4.
#
# Previous content wrote /etc/nftables.d/10-mark-offload.nft which
# caused "No such file or directory" errors on the flow offload action.
# Removing it to let fw4 handle offload natively.

rm -f /etc/nftables.d/10-mark-offload.nft

exit 0
