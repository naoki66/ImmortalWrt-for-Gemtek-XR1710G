From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Yanghan Ye <yyh94306@gmail.com>
Date: Sun, 10 May 2026 03:09:19 +0800
Subject: [PATCH] wifi: mt76: mt7996: promote faster AP MLO link for AMPDU

When an AP MLO station has a higher-numbered active link, promote it as the default link for TX queue and AMPDU handling while keeping the older link as the secondary link. This keeps AMPDU setup on the faster AP MLO data link.

Signed-off-by: Yanghan Ye <yyh94306@gmail.com>
---
 mt7996/main.c | 38 ++++++++++++++++++++++++++++++--------
 1 file changed, 30 insertions(+), 8 deletions(-)

diff --git a/mt7996/main.c b/mt7996/main.c
index eec562d..9969c57 100644
--- a/mt7996/main.c
+++ b/mt7996/main.c
@@ -1289,6 +1289,20 @@ mt7996_mac_sta_add_link(struct mt7996_dev *dev, struct ieee80211_vif *vif,
 
 	mphy->num_sta++;
 
+	if (sta->mlo && vif->type == NL80211_IFTYPE_AP &&
+	    ieee80211_vif_is_mld(vif) &&
+	    msta->deflink_id != IEEE80211_LINK_UNSPECIFIED &&
+	    link_id > msta->deflink_id) {
+		msta_link = mt7996_sta_link_protected(dev, msta, link_id);
+		if (msta_link) {
+			u8 old_deflink = msta->deflink_id;
+
+			msta->deflink_id = link_id;
+			msta->seclink_id = old_deflink;
+			mt7996_sta_init_txq_wcid(sta, msta_link->wcid.idx);
+		}
+	}
+
 	return 0;
 }
 
@@ -1629,6 +1643,7 @@ mt7996_ampdu_action(struct ieee80211_hw *hw, struct ieee80211_vif *vif,
 	u16 tid = params->tid;
 	u16 ssn = params->ssn;
 	struct mt76_wcid *tx_agg_wcid = &msta->deflink.wcid;
+	struct mt76_wcid *rx_agg_wcid = &msta->deflink.wcid;
 	struct mt76_txq *mtxq;
 	int ret = 0;
 
@@ -1639,14 +1654,21 @@ mt7996_ampdu_action(struct ieee80211_hw *hw, struct ieee80211_vif *vif,
 
 	mutex_lock(&dev->mt76.mutex);
 
-	if (sta->mlo && vif->type == NL80211_IFTYPE_AP &&
-	    ieee80211_vif_is_mld(vif) &&
-	    msta->seclink_id != IEEE80211_LINK_UNSPECIFIED &&
-	    msta->seclink_id != msta->deflink_id) {
+	if (sta->mlo && ieee80211_vif_is_mld(vif)) {
 		struct mt7996_sta_link *msta_link;
+		u8 tx_link_id = msta->deflink_id;
+
+		msta_link = mt7996_sta_link_protected(dev, msta, msta->deflink_id);
+		if (msta_link)
+			rx_agg_wcid = &msta_link->wcid;
+
+		if (vif->type == NL80211_IFTYPE_AP &&
+		    msta->seclink_id != IEEE80211_LINK_UNSPECIFIED &&
+		    msta->seclink_id != msta->deflink_id)
+			tx_link_id = (tid % 2) ? msta->seclink_id
+					       : msta->deflink_id;
 
-		msta_link = mt7996_sta_link_protected(dev, msta,
-						      msta->seclink_id);
+		msta_link = mt7996_sta_link_protected(dev, msta, tx_link_id);
 		if (msta_link)
 			tx_agg_wcid = &msta_link->wcid;
 	}
@@ -1657,12 +1679,12 @@ mt7996_ampdu_action(struct ieee80211_hw *hw, struct ieee80211_vif *vif,
 		 * multiple links, store the AMPDU state for reordering in the
 		 * primary link
 		 */
-		mt76_rx_aggr_start(&dev->mt76, &msta->deflink.wcid, tid,
+		mt76_rx_aggr_start(&dev->mt76, rx_agg_wcid, tid,
 				   ssn, params->buf_size);
 		ret = mt7996_mcu_add_rx_ba(dev, params, vif, true);
 		break;
 	case IEEE80211_AMPDU_RX_STOP:
-		mt76_rx_aggr_stop(&dev->mt76, &msta->deflink.wcid, tid);
+		mt76_rx_aggr_stop(&dev->mt76, rx_agg_wcid, tid);
 		ret = mt7996_mcu_add_rx_ba(dev, params, vif, false);
 		break;
 	case IEEE80211_AMPDU_TX_OPERATIONAL:
